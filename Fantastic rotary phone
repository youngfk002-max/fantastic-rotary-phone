<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Professional Landing Page</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      line-height: 1.6;
      color: #333;
    }
    header {
      background: #004080;
      color: #fff;
      padding: 1rem 2rem;
    }
    header h1 {
      margin: 0;
    }
    nav {
      margin-top: 0.5rem;
    }
    nav a {
      color: #fff;
      margin-right: 1rem;
      text-decoration: none;
      font-weight: bold;
    }
    .hero {
      background: url('https://via.placeholder.com/1200x400') no-repeat center center/cover;
      color: #fff;
      text-align: center;
      padding: 5rem 2rem;
    }
    .hero h2 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }
    .hero p {
      font-size: 1.2rem;
    }
    .content {
      padding: 2rem;
    }
    .content h3 {
      color: #004080;
    }
    footer {
      background: #f4f4f4;
      text-align: center;
      padding: 1rem;
      margin-top: 2rem;
    }
  </style>
</head>
<body>
  <header>
    <h1>My Company</h1>
    <nav>
      <a href="#about">About</a>
      <a href="#services">Services</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <section class="hero">
    <h2>Welcome to Our Professional Space</h2>
    <p>Delivering excellence through innovation and dedication.</p>
  </section>

  <section class="content" id="about">
    <h3>About Us</h3>
    <p>We are a team of professionals committed to providing top-notch solutions tailored to your needs.</p>
  </section>

  <section class="content" id="services">
    <h3>Our Services</h3>
    <ul>
      <li>Consulting and Strategy</li>
      <li>Web Development</li>
      <li>Design and Branding</li>
    </ul>
  </section>

  <section class="content" id="contact">
    <h3>Contact Us</h3>
    <p>Email: info@mycompany.com</p>
    <p>Phone: +234 800 123 4567</p>
  </section>

  <footer>
    <p>&copy; 2026 My Company. All rights reserved.</p>
  </footer>
</body>
</html>>
